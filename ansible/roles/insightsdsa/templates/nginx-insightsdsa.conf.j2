upstream insightsdsa_uwsgi {
    server unix:{{ insightsdsa_uwsgi_socket }};
}

server {
    listen 80;
    server_name {{ insightsdsa_server_name }};

    access_log {{ insightsdsa_nginx_access_log }} {{ insightsdsa_nginx_access_log_format }};
    error_log {{ insightsdsa_nginx_error_log }};

{% if insightsdsa_https_enabled | default(false) | bool %}
    return 301 https://$host$request_uri;
{% else %}
    client_max_body_size 20m;

    location / {
        include uwsgi_params;
        uwsgi_pass insightsdsa_uwsgi;
        uwsgi_read_timeout {{ insightsdsa_uwsgi_harakiri | int + 30 }}s;
    }
{% endif %}
}

{% if insightsdsa_https_enabled | default(false) | bool %}
server {
    listen 443 ssl http2;
    server_name {{ insightsdsa_server_name }};

    access_log {{ insightsdsa_nginx_access_log }} {{ insightsdsa_nginx_access_log_format }};
    error_log {{ insightsdsa_nginx_error_log }};

    ssl_certificate {{ insightsdsa_tls_fullchain_path }};
    ssl_certificate_key {{ insightsdsa_tls_privkey_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 20m;

    location / {
        include uwsgi_params;
        uwsgi_pass insightsdsa_uwsgi;
        uwsgi_read_timeout {{ insightsdsa_uwsgi_harakiri | int + 30 }}s;
    }
}
{% endif %}
