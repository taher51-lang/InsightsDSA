# Managed by Ansible — do not edit on server.
DATABASE_URL=postgresql+psycopg://{{ insightsdsa_db_user | urlencode }}:{{ insightsdsa_db_password | urlencode }}@{{ insightsdsa_postgres_host }}:{{ insightsdsa_postgres_port }}/{{ insightsdsa_db_name }}
CHECKPOINT_DATABASE_URL=postgresql://{{ insightsdsa_db_user | urlencode }}:{{ insightsdsa_db_password | urlencode }}@{{ insightsdsa_postgres_host }}:{{ insightsdsa_postgres_port }}/{{ insightsdsa_db_name }}

FLASK_SECRET_KEY={{ insightsdsa_flask_secret_key }}
ENCRYPTION_KEY={{ insightsdsa_encryption_key }}

INSIGHTSDSA_USE_MEMORY_REDIS=false
REDIS_HOST={{ insightsdsa_redis_host }}
REDIS_PORT={{ insightsdsa_redis_port }}
REDIS_DB={{ insightsdsa_redis_db }}
{% if insightsdsa_redis_password | length > 0 %}
REDIS_PASSWORD={{ insightsdsa_redis_password }}
{% endif %}

SESSION_COOKIE_SECURE={{ insightsdsa_session_cookie_secure | lower }}
SESSION_COOKIE_SAMESITE={{ insightsdsa_session_cookie_samesite }}

GOOGLE_CLIENT_ID={{ insightsdsa_google_client_id | default('', true) }}
GOOGLE_CLIENT_SECRET={{ insightsdsa_google_client_secret | default('', true) }}
{% set _sn = insightsdsa_server_name | default('_', true) | string | trim %}
{% set _explicit_uri = insightsdsa_google_redirect_uri | default('', true) | string | trim %}
{% if _explicit_uri | length > 0 %}
GOOGLE_REDIRECT_URI={{ _explicit_uri }}
{% elif _sn not in ['', '_'] %}
{% if insightsdsa_tls_mode | default('none') in ['selfsigned', 'letsencrypt'] %}
GOOGLE_REDIRECT_URI=https://{{ _sn }}/login/callback
{% else %}
GOOGLE_REDIRECT_URI=http://{{ _sn }}/login/callback
{% endif %}
{% endif %}

LOG_DIR={{ insightsdsa_log_dir }}
LOG_FILE=logiclens.log
